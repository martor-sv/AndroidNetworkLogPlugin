<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- 暗色主题，继承 Material DayNight（NoActionBar 避免手动设置 Toolbar 时冲突） -->
    <style name="Theme.NetworkLog" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/net_toolbar</item>
        <item name="colorPrimaryDark">@color/net_bg</item>
        <item name="colorAccent">@color/net_accent</item>
        <item name="android:windowBackground">@color/net_bg</item>
        <item name="tabTextColor">#FFFFFF</item>
        <item name="tabSelectedTextColor">@color/net_accent</item>
        <item name="tabIndicatorColor">@color/net_accent</item>
        <item name="titleTextColor">#FFFFFF</item>
    </style>
</resources>
